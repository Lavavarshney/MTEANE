# ─────────────────────────────────────────────────────────────────
# Triggrr Producer App — environment variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────

# URL where your Triggrr API is running (must match root .env PORT).
# Local:  http://localhost:8080  (if PORT=8080) or http://localhost:3000 (default)
# Deployed: https://your-triggrr.fly.dev
TRIGGRR_URL=http://localhost:8080

# Optional: same URL for the sidebar footer (browser-visible only; no secrets).
NEXT_PUBLIC_TRIGGRR_URL=http://localhost:8080

# API key issued by Triggrr at POST /auth/register.
# Run `npm run seed` in the Triggrr root for a dev key,
# or register via POST /auth/register and copy the api_key field.
TRIGGRR_API_KEY=your-api-key-here
