# ──────────────────────────────────────────────────────────────────────────────
# Triggrr — environment variables
# Copy this file to .env and fill in the values.
# On Fly.io, set these as secrets:  fly secrets set KEY=value
# On docker-compose, these are optional — defaults are in docker-compose.yml
# ──────────────────────────────────────────────────────────────────────────────

# Application
PORT=3000
NODE_ENV=development

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# For docker-compose: postgresql://triggrr:triggrr@localhost:5432/triggrr
# For production: Dashboard → Project → Connection string  (choose "Node.js" driver)
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql://triggrr:triggrr@localhost:5432/triggrr

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# For docker-compose: redis://localhost:6379
# For production: Dashboard → Database → Connect → ioredis  (copy the rediss:// URL)
# Format: redis[s]://[password@]<host>:<port>
REDIS_URL=redis://localhost:6379

# ── API Key Secret ─────────────────────────────────────────────────────────────
# Used to HMAC-sign API keys before storing the hash in the database.
# Generate your own with: openssl rand -hex 32
# NEVER commit your real secret — use a secrets manager or fly secrets set in production.
API_KEY_SECRET=a3f8e2c1d94b6071f52890abcde34f67a1b2c3d4e5f6071819202122232425a6

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ── Worker Configuration ──────────────────────────────────────────────────────
# Concurrency for the BullMQ worker
WORKER_CONCURRENCY=5

# ── SMTP (Email Executor) ──────────────────────────────────────────────────────
# Optional — only required when using action_type: "email" in rules
# For local dev, point at Mailhog: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@triggrr.io
